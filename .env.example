# Copy to .env for local dev (never commit .env)
# Firebase config is in src/firebase.js — no Firebase env vars required for build.

# Optional — only if using Supabase server functions locally:
# SUPABASE_URL=
# SUPABASE_PUBLISHABLE_KEY=
# VITE_SUPABASE_URL=
# VITE_SUPABASE_PUBLISHABLE_KEY=

# Optional — OpenAI image generation (disabled in app by default):
# OPENAI_API_KEY=
