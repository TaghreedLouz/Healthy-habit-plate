rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return signedIn()
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin";
    }

    match /recipes/{recipeId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /settings/stats {
      allow read: if true;
      allow create: if signedIn()
        && request.resource.data.keys().hasOnly(["registeredUsers"])
        && request.resource.data.registeredUsers == 1;
      allow update: if signedIn()
        && request.resource.data.keys().hasOnly(["registeredUsers"])
        && request.resource.data.registeredUsers == resource.data.registeredUsers + 1
        && !exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    match /settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /users/{userId} {
      allow get: if signedIn() && (request.auth.uid == userId || isAdmin());
      allow list: if isAdmin();
      allow create: if signedIn() && request.auth.uid == userId;
      allow update: if signedIn() && (request.auth.uid == userId || isAdmin());
      allow delete: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
